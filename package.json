{
  "name": "kovas-panel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "migrate": "node --env-file=.env.local --import tsx scripts/migrate.ts",
    "create-admin": "node --env-file=.env.local --import tsx scripts/create-admin.ts",
    "backfill": "node --conditions=react-server --env-file=.env.local --import tsx scripts/backfill.ts",
    "sync-fx": "node --conditions=react-server --env-file=.env.local --import tsx scripts/sync-fx.ts",
    "sync-costs": "node --conditions=react-server --env-file=.env.local --import tsx scripts/sync-costs.ts",
    "refresh-reports": "node --conditions=react-server --env-file=.env.local --import tsx scripts/refresh-reports.ts",
    "import-agents": "node --env-file=.env.local --import tsx scripts/import-easi-agents.ts",
    "preview": "bash scripts/preview.sh start",
    "preview:stop": "bash scripts/preview.sh stop",
    "preview:status": "bash scripts/preview.sh status",
    "compare-totals": "node --conditions=react-server --env-file=.env.local --import tsx scripts/compare-totals.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "exceljs": "^4.4.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
