# Skopiuj do .env.local i uzupełnij wartościami z panelu Turis (Tools -> API Clients)
TURIS_BASE_URL=https://<konto>.turis.app
TURIS_CLIENT_ID=
TURIS_CLIENT_SECRET=

# wFirma: accessKey/secretKey z Ustawienia -> Bezpieczeństwo -> Aplikacje -> Klucze API;
# appKey z formularza wfirma.pl (przychodzi mailem); companyId opcjonalny (tylko przy kilku firmach na koncie)
WFIRMA_ACCESS_KEY=
WFIRMA_SECRET_KEY=
WFIRMA_APP_KEY=
WFIRMA_COMPANY_ID=

# Supabase: Project Settings -> API (Project URL + service_role key - NIE anon key,
# service_role omija RLS i jest potrzebny do zapisu przez sync jobs)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Logowanie użytkowników (Supabase Auth) - te dwie zmienne trafiają do przeglądarki,
# dlatego prefiks NEXT_PUBLIC_ i klucz anon (nie service_role!). Wartość URL ta sama co wyżej.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase: Project Settings -> Database -> Connection string (URI) - do uruchamiania migracji
# SQL (npm run migrate); węższe uprawnienie niż token do całego konta Supabase
SUPABASE_DB_URL=
